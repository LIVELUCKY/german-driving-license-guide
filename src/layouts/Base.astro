---
import '../styles/global.css';
import ClientRouter from 'astro/components/ClientRouter.astro';
import { SEO } from 'astro-seo';
import { Icon } from 'astro-icon/components';
import { Image, getImage } from 'astro:assets';
import logoSrc from '../assets/logo.jpg';
import { NAV, urlFor, prevNext, t, withBase, LOCALES, DEFAULT_LANG, isRTL } from '../lib/i18n.js';
import { makeT } from '../lib/dict.js';
import Analytics from '../components/Analytics.astro';
import CookieBanner from '../components/CookieBanner.astro';
const { lang = DEFAULT_LANG, slug = '', title, description } = Astro.props;
const T = makeT(lang);
const { prev, next } = prevNext(lang, slug);
const cur = NAV.find(n => n.slug === slug);
const pageTitle = title ?? (cur ? t(lang, cur.en, cur.de, cur.ar) : 'Führerschein');
const fullTitle = slug === '' ? pageTitle : `${pageTitle} · Führerschein Guide`;
const navItems = NAV.filter(n => n.slug !== '');
const dir = isRTL(lang) ? 'rtl' : 'ltr';
const metaDesc = description ?? t(lang,
  'Bilingual study guide for the German driving licence: signs, theory, practical.',
  'Lernbegleiter für den Führerschein: Zeichen, Theorie, Praxis.',
  'دليل دراسة ثنائي اللغة لرخصة القيادة الألمانية: إشارات، نظرية، تطبيق.');
const ogImage = await getImage({ src: logoSrc, width: 1200, height: 1200, format: 'jpeg' });
const siteBase = Astro.site ?? new URL('https://example.com');
const abs = (p: string) => new URL(p, siteBase).href;
const ogImageUrl = abs(ogImage.src);
---
<!DOCTYPE html>
<html lang={lang} data-lang={lang} dir={dir}>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<!-- astro-seo handles all title/description/OG/Twitter meta in one component -->
<SEO
  title={fullTitle}
  description={metaDesc}
  canonical={abs(urlFor(lang, slug))}
  openGraph={{
    basic: { title: fullTitle, type: 'website', url: abs(urlFor(lang, slug)), image: ogImageUrl },
    optional: { description: metaDesc, locale: lang },
  }}
  twitter={{ card: 'summary', title: fullTitle, description: metaDesc }}
  noindex={false}
  extend={{
    link: [
      ...LOCALES.map(l => ({ rel: 'alternate', hreflang: l, href: abs(urlFor(l, slug)) })),
      { rel: 'alternate', hreflang: 'x-default', href: abs(urlFor(DEFAULT_LANG, slug)) },
      { rel: 'preload', href: withBase('fonts/archivo-black-latin-400-normal.woff2'), as: 'font', type: 'font/woff2', crossorigin: '' },
      { rel: 'preload', href: withBase('fonts/space-grotesk-latin-400-normal.woff2'), as: 'font', type: 'font/woff2', crossorigin: '' },
      { rel: 'icon', href: "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%2316161a'/><rect x='10' y='10' width='80' height='80' fill='none' stroke='%23ffd400' stroke-width='9'/><text x='50' y='67' font-size='40' font-weight='800' fill='white' text-anchor='middle' font-family='Arial Black,Arial'>DE</text></svg>" },
      { rel: 'alternate', type: 'application/rss+xml', title: 'Führerschein Guide — Study Tips', href: withBase('rss.xml') },
    ],
  }}
/>
<!-- Font faces — absolute paths via withBase() so /de/ and /ar/ routes resolve correctly -->
<style set:html={`
@font-face{font-family:'Space Grotesk';font-style:normal;font-weight:400;font-display:swap;src:url('${withBase('fonts/space-grotesk-latin-400-normal.woff2')}') format('woff2');unicode-range:U+0000-00FF}
@font-face{font-family:'Space Grotesk';font-style:normal;font-weight:500;font-display:swap;src:url('${withBase('fonts/space-grotesk-latin-500-normal.woff2')}') format('woff2');unicode-range:U+0000-00FF}
@font-face{font-family:'Space Grotesk';font-style:normal;font-weight:700;font-display:swap;src:url('${withBase('fonts/space-grotesk-latin-700-normal.woff2')}') format('woff2');unicode-range:U+0000-00FF}
@font-face{font-family:'Space Grotesk';font-style:normal;font-weight:400;font-display:swap;src:url('${withBase('fonts/space-grotesk-latin-ext-400-normal.woff2')}') format('woff2');unicode-range:U+0100-024F,U+1E00-1EFF}
@font-face{font-family:'Space Grotesk';font-style:normal;font-weight:700;font-display:swap;src:url('${withBase('fonts/space-grotesk-latin-ext-700-normal.woff2')}') format('woff2');unicode-range:U+0100-024F,U+1E00-1EFF}
@font-face{font-family:'Archivo Black';font-style:normal;font-weight:400;font-display:swap;src:url('${withBase('fonts/archivo-black-latin-400-normal.woff2')}') format('woff2');unicode-range:U+0000-00FF}
@font-face{font-family:'Archivo Black';font-style:normal;font-weight:400;font-display:swap;src:url('${withBase('fonts/archivo-black-latin-ext-400-normal.woff2')}') format('woff2');unicode-range:U+0100-024F}
`} />
<!-- PWA manifest + SW injected by @vite-pwa/astro at build time -->
<ClientRouter />
<script is:inline>
// Apply theme immediately to avoid flash on hard load
(function(){try{document.documentElement.dataset.theme=localStorage.getItem('fs_theme')||'light';}catch(e){document.documentElement.dataset.theme='light';}})();
// Carry theme into every View Transition swap — Astro resets <html> attrs from new doc otherwise
document.addEventListener('astro:before-swap',function(e){
  try{e.newDocument.documentElement.dataset.theme=localStorage.getItem('fs_theme')||'light';}catch(e){}
});
</script>
<Analytics />
</head>
<body>
<a class="skip" href="#main">{T('a11y.skip')}</a>
<header class="bar"><div class="wrap row">
  <a class="brand" href={urlFor(lang, '')}>
    <Image src={logoSrc} width={36} height={36} alt="Führerschein Guide" class="brand-logo" widths={[36, 72]} sizes="36px" loading="eager" />
    <span>Führerschein<small>{T('brand.tag')}</small></span>
  </a>
  <nav class="dnav" aria-label={T('nav.menu')}>
    {navItems.map(n => (
      <a class={slug === n.slug ? 'on' : ''} href={urlFor(lang, n.slug)} aria-current={slug === n.slug ? 'page' : undefined}>
        {t(lang, n.en, n.de, n.ar)}
      </a>
    ))}
  </nav>
  <div class="spacer"></div>
  <nav class="ctrl" aria-label={T('a11y.language')}>
    {LOCALES.map(l => (
      <a class={lang === l ? 'on' : ''}
         href={lang === l ? undefined : urlFor(l, slug)}
         aria-current={lang === l ? 'true' : undefined}
         lang={l}
         onclick={lang !== l ? `if(typeof __fsTrack==='function')__fsTrack('language_switch',{from:'${lang}',to:'${l}'})` : undefined}
         >{l === 'ar' ? 'عر' : l.toUpperCase()}</a>
    ))}
  </nav>
  <button class="iconbtn" id="themeBtn" aria-label={T('a11y.theme')}>
    <Icon name="lucide:moon" id="iconMoon" size={18} />
    <Icon name="lucide:sun" id="iconSun" size={18} style="display:none" />
  </button>
  <button class="iconbtn navtoggle" id="navBtn" aria-label={T('a11y.nav')} aria-expanded="false">
    <Icon name="lucide:menu" id="iconMenu" size={18} />
    <Icon name="lucide:x" id="iconClose" size={18} style="display:none" />
  </button>
</div></header>

<nav class="mnav" id="mnav" aria-label={T('nav.menu')}>
  {navItems.map((n, i) => (
    <a href={urlFor(lang, n.slug)}>
      <span class="no">{String(i + 1).padStart(2, '0')}</span>
      {t(lang, n.en, n.de, n.ar)}
    </a>
  ))}
</nav>

{slug !== '' && (
  <div class="wrap crumbs">
    <a href={urlFor(lang, '')}>{T('crumb.home')}</a>
    <span>/</span>
    <span>{pageTitle}</span>
  </div>
)}

<main id="main">
  <slot />
</main>

{slug !== '' && (prev || next) && (
  <div class="wrap pn">
    {prev ? <a href={prev.url}><span class="dir"><Icon name="lucide:arrow-left" size={13} /> {T('pn.prev')}</span><span class="t">{prev.title}</span></a> : <span></span>}
    {next ? <a class="next" href={next.url}><span class="dir">{T('pn.next')} <Icon name="lucide:arrow-right" size={13} /></span><span class="t">{next.title}</span></a> : <span></span>}
  </div>
)}

<footer><div class="wrap">
  <div class="ft-row">
    <div class="ft">Führerschein Guide</div>
    <div class="ft-links">
      <a href={urlFor(lang, 'legal')}>{T('nav.legal')}</a>
      {lang !== 'de' && <a href={urlFor('de', slug)}>Auf Deutsch</a>}
      {lang !== 'en' && <a href={urlFor('en', slug)}>In English</a>}
      {lang !== 'ar' && <a href={urlFor('ar', slug)}>بالعربية</a>}
    </div>
  </div>
  <small>{T('footer.line1')}</small>
  <small>⚠️ {T('footer.line2')}</small>
  <small>🖨️ {T('footer.print')}</small>
  <div class="ft-author">
    <span>by Nazmi</span>
    <a href="https://www.linkedin.com/in/0-nazmi/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
    </a>
    <a href="https://github.com/LIVELUCKY" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
    </a>
  </div>
</div></footer>

<script is:inline define:vars={{ darkLabel: T('theme.dark'), lightLabel: T('theme.light'), pageLang: lang, pageSlug: slug }}>
function paintTheme(){
  var d=document.documentElement.dataset.theme==='dark';
  var b=document.getElementById('themeBtn');
  if(b)b.setAttribute('aria-label',d?lightLabel:darkLabel);
  var m=document.getElementById('iconMoon'),s=document.getElementById('iconSun');
  if(m&&s){m.style.display=d?'none':'';s.style.display=d?'':'none';}
}

// ── Per-page init: runs after EVERY View Transition navigation ────────────────
function fsPageInit(){
  // Restore hash scroll after View Transition
  var hash=window.location.hash;
  if(hash){var t=document.getElementById(hash.slice(1));if(t)t.scrollIntoView({behavior:'instant',block:'start'});}

  // Track page view
  if(typeof window.__fsTrack==='function') window.__fsTrack('page_view',{page_path:location.pathname,page_lang:pageLang});

  // Theme toggle — rebind every page (View Transitions replace DOM)
  var b=document.getElementById('themeBtn');
  if(b&&!b.dataset.bound){
    b.dataset.bound='1';
    b.addEventListener('click',function(){
      var next=document.documentElement.dataset.theme==='dark'?'light':'dark';
      document.documentElement.dataset.theme=next;
      try{localStorage.setItem('fs_theme',next)}catch(e){}
      if(typeof window.__fsTrack==='function') window.__fsTrack('theme_toggle',{theme:next});
      paintTheme();
    });
  }
  paintTheme();

  // Mobile nav toggle
  var nb=document.getElementById('navBtn'),mn=document.getElementById('mnav');
  if(mn){mn.classList.remove('open');}
  if(nb&&mn&&!nb.dataset.bound){
    nb.dataset.bound='1';
    nb.addEventListener('click',function(){
      var open=mn.classList.toggle('open');
      nb.setAttribute('aria-expanded',String(open));
      var im=document.getElementById('iconMenu'),ic=document.getElementById('iconClose');if(im&&ic){im.style.display=open?'none':'';ic.style.display=open?'':'none';}
    });
  }

  // Scroll-reveal
  if(matchMedia('(prefers-reduced-motion: no-preference)').matches&&'IntersectionObserver' in window){
    var SELECTORS='.card,.sign-front,.combo,.path a.step,.cathub a.cat,details.more,.bento-item';
    var els=document.querySelectorAll(SELECTORS);
    var groups=new Map();
    els.forEach(function(el){
      if(el.classList.contains('rv'))return;
      el.classList.add('rv');
      var parent=el.parentElement||document.body;
      if(!groups.has(parent))groups.set(parent,[]);
      groups.get(parent).push(el);
    });
    groups.forEach(function(children){
      children.forEach(function(el,i){el.style.transitionDelay=Math.min(i*55,280)+'ms';});
    });
    var io=new IntersectionObserver(function(es){
      es.forEach(function(e){
        if(e.isIntersecting){
          var parent=e.target.parentElement;
          if(parent){parent.querySelectorAll('.rv:not(.in)').forEach(function(s){s.classList.add('in');});}
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      });
    },{rootMargin:'0px 0px -6% 0px',threshold:.06});
    els.forEach(function(el){if(!el.classList.contains('in'))io.observe(el);});
  }

  // Nav link click tracking
  document.querySelectorAll('.bar nav a:not([data-nav-t])').forEach(function(a){
    a.dataset.navT='1';
    a.addEventListener('click',function(){
      if(typeof window.__fsTrack==='function') window.__fsTrack('nav_click',{label:(a.textContent||'').trim(),href:a.getAttribute('href'),lang:pageLang});
    });
  });
  // Outbound link tracking
  document.querySelectorAll('a[href^="http"]:not([data-out-t])').forEach(function(a){
    try{if(new URL(a.href).hostname===location.hostname)return;}catch(e){return;}
    a.dataset.outT='1';
    a.addEventListener('click',function(){
      if(typeof window.__fsTrack==='function') window.__fsTrack('outbound_link',{url:a.href,lang:pageLang});
    });
  });
}
document.addEventListener('astro:page-load', fsPageInit);
if(document.readyState!=='loading') fsPageInit();
</script>
{slug !== 'legal' && <CookieBanner lang={lang} />}
</body>
</html>
