---
import SignCategoryPage from '../../../components/SignCategoryPage.astro';
import { CATS } from '../../../lib/signs.js';
export function getStaticPaths() {
  return ['en', 'ar'].flatMap(lang =>
    CATS.map(c => ({ params: { lang, cat: c.id } }))
  );
}
const { lang, cat } = Astro.params;
---
<SignCategoryPage lang={lang} catId={cat} />
