---
import { t, urlFor } from '../lib/i18n.js';
const { lang } = Astro.props;
---
<div id="cookieBackdrop" class="cookie-backdrop" style="display:none" aria-hidden="true"></div>

<div id="cookieBanner" class="cookie-banner" role="dialog" aria-modal="true"
     aria-label={t(lang,'Cookie consent','Cookie-Einwilligung','موافقة ملفات الارتباط')}
     style="display:none">
  <div class="cookie-icon">🍪</div>
  <div class="cookie-body">
    <p class="cookie-title">{t(lang,'Analytics & privacy','Analyse & Datenschutz','التحليل والخصوصية')}</p>
    <p class="cookie-text">
      {t(lang,
        'We use Google Analytics to understand which pages are useful. No ads, no cross-site tracking.',
        'Wir nutzen Google Analytics um zu sehen, welche Seiten nützlich sind. Keine Werbung, kein seitenübergreifendes Tracking.',
        'نستخدم Google Analytics لمعرفة الصفحات المفيدة. لا إعلانات، لا تتبع عبر المواقع.'
      )}
      {' '}<a href={urlFor(lang, 'legal')}>{t(lang,'Privacy →','Datenschutz →','الخصوصية →')}</a>
    </p>
    <div class="cookie-actions">
      <button id="cookieAccept" class="cookie-btn cookie-btn-yes">
        {t(lang,'Accept analytics','Analyse akzeptieren','قبول التحليل')}
      </button>
      <button id="cookieDecline" class="cookie-btn cookie-btn-no">
        {t(lang,'No thanks','Nein danke','لا شكراً')}
      </button>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  function initBanner() {
    var banner = document.getElementById('cookieBanner');
    var backdrop = document.getElementById('cookieBackdrop');
    if (!banner || banner.dataset.init) return;
    banner.dataset.init = '1';

    try { if (localStorage.getItem('fs_consent')) return; } catch(e) {}

    function show() {
      backdrop.style.display = '';
      banner.style.display = '';
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          banner.classList.add('cookie-visible');
          backdrop.classList.add('cookie-visible');
        });
      });
      // Focus first button for accessibility
      setTimeout(function() {
        var btn = banner.querySelector('button');
        if (btn) btn.focus();
      }, 350);
    }

    function hide(choice) {
      banner.classList.remove('cookie-visible');
      backdrop.classList.remove('cookie-visible');
      banner.classList.add('cookie-exit');
      setTimeout(function() {
        banner.style.display = 'none';
        backdrop.style.display = 'none';
        banner.classList.remove('cookie-exit');
      }, 380);
      if (typeof window.__gaConsent === 'function') {
        window.__gaConsent(choice);
      } else {
        try { localStorage.setItem('fs_consent', choice); } catch(e) {}
      }
    }

    setTimeout(show, 700);

    document.getElementById('cookieAccept').addEventListener('click', function() { hide('granted'); });
    document.getElementById('cookieDecline').addEventListener('click', function() { hide('denied'); });
    // Backdrop click does NOT dismiss — user must choose
  }

  document.addEventListener('astro:page-load', initBanner);
  if (document.readyState !== 'loading') initBanner();
})();
</script>

<style>
.cookie-backdrop {
  position: fixed;
  inset: 0;
  z-index: 49; /* below header (z-index:50) so lang/theme switcher stays clickable */
  background: rgba(0,0,0,.5);
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
  opacity: 0;
  transition: opacity .3s ease;
  pointer-events: all;
  cursor: default;
}
.cookie-backdrop.cookie-visible { opacity: 1; }

.cookie-banner {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  background: var(--surface);
  border-top: 3px solid var(--ink);
  box-shadow: 0 -8px 40px rgba(0,0,0,.25);
  padding: clamp(20px,3vw,32px) clamp(16px,4vw,40px);
  display: flex;
  align-items: flex-start;
  gap: 20px;
  transform: translateY(105%);
  transition: transform .38s cubic-bezier(.22,1,.36,1);
}
.cookie-banner.cookie-visible {
  transform: translateY(0);
}
.cookie-banner.cookie-exit {
  transform: translateY(105%);
  transition: transform .35s cubic-bezier(.55,0,1,.45);
}

.cookie-icon {
  font-size: 2.4rem;
  flex: none;
  line-height: 1;
  animation: cookieBounce .6s .9s both;
}
@keyframes cookieBounce {
  0%   { transform: scale(0) rotate(-30deg); opacity: 0 }
  60%  { transform: scale(1.2) rotate(8deg) }
  100% { transform: scale(1) rotate(0); opacity: 1 }
}

.cookie-body { flex: 1; max-width: 820px; }

.cookie-title {
  font-family: var(--display);
  font-size: 1.05rem;
  text-transform: uppercase;
  letter-spacing: .04em;
  margin: 0 0 6px;
  color: var(--ink);
}

.cookie-text {
  font-size: .85rem;
  color: var(--muted);
  margin: 0 0 16px;
  line-height: 1.55;
}
.cookie-text a {
  color: var(--pop2);
  text-decoration: underline;
  text-underline-offset: 3px;
  font-weight: 600;
}

.cookie-actions { display: flex; gap: 10px; flex-wrap: wrap; }

.cookie-btn {
  padding: 11px 24px;
  font-size: .88rem;
  font-weight: 700;
  border-radius: var(--r);
  cursor: pointer;
  font-family: var(--font);
  border: 2px solid var(--line);
  transition: transform .15s var(--ease), box-shadow .15s var(--ease), background .15s;
  position: relative;
}
.cookie-btn:hover  { transform: translate(-2px,-2px); }
.cookie-btn:active { transform: translate(1px,1px); }
.cookie-btn-yes {
  background: var(--ink);
  color: var(--bg);
  box-shadow: 4px 4px 0 var(--pop);
}
.cookie-btn-yes:hover { box-shadow: 6px 6px 0 var(--pop); }
.cookie-btn-no {
  background: transparent;
  color: var(--muted);
  box-shadow: 4px 4px 0 var(--line);
}
.cookie-btn-no:hover { color: var(--ink); box-shadow: 6px 6px 0 var(--line); }

@media(max-width:480px) {
  .cookie-icon { display: none; }
  .cookie-banner { padding: 16px; }
  .cookie-actions { flex-direction: column; }
  .cookie-btn { text-align: center; }
}
</style>
