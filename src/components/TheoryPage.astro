---
import Base from '../layouts/Base.astro';
import Card from './Card.astro';
import PageHead from './PageHead.astro';
import Section from './Section.astro';
import DisclosureList from './DisclosureList.astro';
import { t } from '../lib/i18n.js';
import { THEORY } from '../lib/content.js';
const { lang } = Astro.props;
const core = THEORY.slice(0, 7);
const deep = THEORY.slice(7);
---
<Base lang={lang} slug="theory">
  <PageHead
    kicker={t(lang,'For the written exam','Für die Theorieprüfung','للاختبار النظري')}
    title={t(lang,'Theory essentials','Theorie-Wissen','أساسيات النظرية')}
    lead={t(lang,
      'The core first — formulas and rules the exam loves. Below that, the deeper topic blocks when you\'re ready for them.',
      'Erst der Kern — Formeln und Regeln, die die Prüfung liebt. Darunter die vertiefenden Blöcke, wenn du bereit bist.',
      'الأساسيات أولاً — الصيغ والقواعد التي يحبها الامتحان. ثم الموضوعات الأعمق عندما تكون مستعداً.')}
    toc={[
      { href: '#core', label: t(lang,'Core rules','Kernregeln','القواعد الأساسية') },
      { href: '#deep', label: t(lang,'Deeper topics','Vertiefung','موضوعات أعمق') },
    ]}
  />
  <Section id="core" title={t(lang,'🎯 The core','🎯 Der Kern','🎯 الأساسيات')}>
    <div class="grid cols2">
      {core.map(c => <Card card={c} lang={lang} />)}
    </div>
  </Section>
  <Section id="deep" title={t(lang,'📚 Deeper topics','📚 Vertiefung','📚 موضوعات أعمق')}>
    <p class="note note-mb">{t(lang,'Open the blocks as you need them — no need to swallow everything at once.','Öffne die Blöcke nach Bedarf — du musst nicht alles auf einmal schlucken.','افتح الأقسام حسب الحاجة — لا داعي لابتلاع كل شيء دفعة واحدة.')}</p>
    <DisclosureList items={deep} lang={lang} />
  </Section>
  <script is:inline define:vars={{ lang }}>
  (function(){var D=[25,50,75,100];function init(){var s=new Set();function c(){var p=Math.round((scrollY+innerHeight)/document.documentElement.scrollHeight*100);D.forEach(function(d){if(p>=d&&!s.has(d)){s.add(d);if(typeof __fsTrack==='function')__fsTrack('scroll_depth',{depth:d,page:'theory',lang:lang});}});}window.addEventListener('scroll',c,{passive:true});document.addEventListener('astro:before-preparation',function(){window.removeEventListener('scroll',c);},{once:true});}document.addEventListener('astro:page-load',init);if(document.readyState!=='loading')init();})();
  </script>
</Base>
